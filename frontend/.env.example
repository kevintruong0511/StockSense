# Copy file này thành .env rồi điền giá trị thật.
# Các biến này chỉ dùng ở BROWSER — không đặt secrets nhạy cảm ở đây.

# URL gốc của backend Render (không có /api, không có dấu / cuối).
# Để trống khi dev (localhost dùng proxy trong vite.config.js).
VITE_API_URL=https://stocksense.onrender.com

# URL gốc cho WebSocket (thường giống VITE_API_URL, không có /ws).
# Để trống khi dev.
VITE_WS_URL=https://stocksense.onrender.com
